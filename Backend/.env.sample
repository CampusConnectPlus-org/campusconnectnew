# Event Reminder System - Environment Configuration Sample
# Add these variables to your .env file

# ========================================
# EMAIL CONFIGURATION
# ========================================
# Gmail SMTP credentials
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# Note: Use Gmail App Password, not your regular password
# To generate an App Password:
# 1. Go to https://myaccount.google.com/
# 2. Enable 2-Factor Authentication
# 3. Create an App Password (select Mail and Windows Computer)
# 4. Use the generated password as EMAIL_PASS

# ========================================
# EVENT REMINDER SCHEDULER CONFIGURATION
# ========================================
# Cron expression for when to run event reminders
# Format: [minute] [hour] [day] [month] [day-of-week]
# Default: 8:00 AM daily
EVENT_REMINDER_TIME="0 8 * * *"

# Examples of other schedules:
# "0 9 * * *"     → 9:00 AM, every day
# "0 20 * * *"    → 8:00 PM, every day
# "0 8 * * 1-5"   → 8:00 AM, Monday-Friday only
# "0 */3 * * *"   → Every 3 hours
# "0 */6 * * *"   → Every 6 hours
# "30 9 * * *"    → 9:30 AM, every day
# "*/30 * * * *"  → Every 30 minutes (for testing)

# ========================================
# DATABASE CONFIGURATION
# ========================================
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/dbname

# ========================================
# OTHER CONFIGURATIONS (if needed)
# ========================================
PORT=5000
NODE_ENV=development

# ========================================
# IMPORTANT NOTES
# ========================================
# 1. Keep EMAIL_USER and EMAIL_PASS secure
# 2. Never commit .env file with real credentials
# 3. Use environment-specific configurations
# 4. Test email sending before relying on scheduler
# 5. Monitor logs for email delivery confirmation

# ========================================
# EVENT REMINDER EMAIL FEATURES
# ========================================
# The system will automatically:
# - Check daily for events starting in 24 hours
# - Send preparation reminders to approved participants
# - Send invitations to non-participants
# - Log all email sending activity
# - Handle failures gracefully
# - Support manual triggering via API

# ========================================
# API ENDPOINTS FOR TESTING
# ========================================
# GET scheduler status:
#   GET http://localhost:5000/api/events/reminders/status
#
# Manually trigger reminders:
#   POST http://localhost:5000/api/events/reminders/trigger
#
# Trigger for specific event:
#   POST http://localhost:5000/api/events/reminders/trigger?eventId=<id>
